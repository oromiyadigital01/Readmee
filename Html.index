</div>

</section>


<!-- FUTURE FEATURES -->

<section class="section">

<h2>🚀 Gara Fuulduraa</h2>

<div class="cards">

<div class="card">
<h3>📱 Mobile App</h3>
<p>
Android App Oromiyaa Digital.
</p>
</div>


<div class="card">
<h3>💳 Kaffaltii Dijitaalaa</h3>
<p>
